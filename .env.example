# Cloudflare account ID shown on the R2 overview page.
R2_ACCOUNT_ID=
# R2 API token credentials with Object Read & Write permission for R2_BUCKET.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Existing R2 bucket used for temporary proof artifacts.
R2_BUCKET=
# Optional; defaults to https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Optional object-key prefix; defaults to proof.
R2_PREFIX=proof
# Optional; defaults to public. Set to signed for one-week R2 presigned URLs.
PROOF_DOWNLOAD_MODE=public
# Required in public mode; the bucket's r2.dev URL or custom domain.
PROOF_PUBLIC_BASE_URL=
